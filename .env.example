# --- Local Ollama (default) --------------------------------------------------
CLIPPER_BASE_URL=http://localhost:11434/v1
CLIPPER_API_KEY=ollama
CLIPPER_LLM=gemma4

# --- Hosted alternative (e.g. OpenRouter) ------------------------------------
# CLIPPER_BASE_URL=https://openrouter.ai/api/v1
# CLIPPER_API_KEY=sk-or-...
# CLIPPER_LLM=google/gemma-3-27b-it

# --- Native video input (Gemma 4 31B via OpenRouter BYOK / AI Studio) --------
# Use with `extract --analyzer gemma-video`. Sends the actual video clip
# inline (base64 data URL) instead of sampled frames; Gemma internally
# samples at 1 fps. Inputs longer than 480 s are chunked client-side.
# CLIPPER_BASE_URL=https://openrouter.ai/api/v1
# CLIPPER_API_KEY=sk-or-...
# CLIPPER_LLM=google/gemma-4-31b-it:free

# --- Stitch (TTS) ------------------------------------------------------------
# ELEVENLABS_API_KEY=sk_...

# --- Gemini (required when using --analyzer gemma-video via AI Studio) -------
# GEMINI_API_KEY=...
